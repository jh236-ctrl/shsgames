---
import Layout from '../layouts/Layout.astro';
import games from '../game.ts';
---

<Layout>
	<main>
		<h1>🕹️ Game Repository</h1>
		<div class="game-grid">
			{games.map((game) => (
				<div class="game-card">
					<img src={game.thumbnail} alt={game.name} />
					<div class="card-info">
						<h3>{game.name}</h3>
						<span>{game.runner}</span>
					</div>
				</div>
			))}
		</div>
	</main>
</Layout>

<style>
	main {
		margin: auto;
		padding: 1.5rem;
		max-width: 1200px;
		color: white;
		font-family: sans-serif;
	}
	h1 {
		font-size: 2.5rem;
		font-weight: 700;
		line-height: 1;
		text-align: center;
		margin-bottom: 2em;
	}
	.game-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
		gap: 2rem;
		padding: 0;
	}
	.game-card {
		background: #23262d;
		border-radius: 8px;
		overflow: hidden;
		transition: transform 0.2s;
	}
	.game-card:hover {
		transform: scale(1.03);
		cursor: pointer;
	}
	.game-card img {
		width: 100%;
		height: 150px;
		object-fit: cover;
	}
	.card-info {
		padding: 1rem;
	}
	h3 {
		margin: 0 0 0.5rem 0;
		font-size: 1.15rem;
	}
	span {
		font-size: 0.8rem;
		background: #444;
		padding: 0.2rem 0.5rem;
		border-radius: 4px;
		opacity: 0.8;
	}
</style>
</Layout>

